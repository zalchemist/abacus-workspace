# =============================================================================
# MariaDB Advanced Performance Configuration
# =============================================================================
# Server: 61GB RAM, 8 CPU Cores, ~900GB Disk
# MariaDB Version: 10.11.14
# Database: BizniSoft ERP (643 tables, 265 triggers, 149 procedures)
# Generated: 2026-03-29
# =============================================================================
#
# This configuration is optimized for a dedicated database server running
# a large ERP system with heavy trigger/procedure usage and complex queries.
# =============================================================================

[mysqld]

# =============================================================================
# InnoDB Storage Engine Settings (Most Critical for Performance)
# =============================================================================

innodb_buffer_pool_size = 40G
innodb_buffer_pool_instances = 8
innodb_log_file_size = 1G
innodb_log_buffer_size = 256M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
innodb_file_per_table = 1
innodb_read_io_threads = 8
innodb_write_io_threads = 8
innodb_io_capacity = 2000
innodb_io_capacity_max = 4000
innodb_purge_threads = 4
innodb_lru_scan_depth = 2048
innodb_open_files = 4000
innodb_buffer_pool_dump_at_shutdown = ON
innodb_buffer_pool_load_at_startup = ON
innodb_buffer_pool_dump_pct = 75
innodb_adaptive_hash_index = OFF
innodb_stats_persistent = ON
innodb_stats_persistent_sample_pages = 40
innodb_print_all_deadlocks = ON

# =============================================================================
# Query Cache Settings
# =============================================================================

query_cache_type = 1
query_cache_size = 256M
query_cache_limit = 8M
query_cache_min_res_unit = 4096

# =============================================================================
# Thread and Connection Settings
# =============================================================================

thread_cache_size = 100
thread_pool_size = 8
max_connections = 200
max_allowed_packet = 1G
wait_timeout = 86400
interactive_timeout = 86400
net_read_timeout = 7200
net_write_timeout = 7200

# =============================================================================
# Table Cache Settings
# =============================================================================

table_open_cache = 4000
table_open_cache_instances = 8
table_definition_cache = 2000

# =============================================================================
# Buffer Settings (Per-Session)
# =============================================================================

sort_buffer_size = 8M
join_buffer_size = 8M
read_buffer_size = 4M
read_rnd_buffer_size = 8M
bulk_insert_buffer_size = 64M
myisam_sort_buffer_size = 128M

# =============================================================================
# Temporary Table Settings
# =============================================================================

tmp_table_size = 512M
max_heap_table_size = 512M

# =============================================================================
# Logging Settings
# =============================================================================

slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 2
log_queries_not_using_indexes = ON
log_throttle_queries_not_using_indexes = 60

# =============================================================================
# Aria Storage Engine Settings
# =============================================================================

aria_pagecache_buffer_size = 256M

# =============================================================================
# Key Buffer (for MyISAM tables)
# =============================================================================

key_buffer_size = 256M

# =============================================================================
# Performance Schema and Monitoring
# =============================================================================

performance_schema = ON

# =============================================================================
# Character Set and Collation
# =============================================================================

character_set_server = utf8mb4
collation_server = utf8mb4_general_ci

# =============================================================================
# Security and Limits
# =============================================================================

max_connect_errors = 1000000
open_files_limit = 65535
